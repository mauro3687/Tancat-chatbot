rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Config — lectura y escritura pública (dashboard sin Firebase Auth)
    match /config/{docId} {
      allow read, write: if true;
    }

    // Reservas — público (el bot crea reservas sin auth, el dashboard las gestiona)
    match /reservas/{docId} {
      allow read, write: if true;
    }

    // Clientes — público (el bot crea clientes sin auth, el dashboard los gestiona)
    match /clientes/{docId} {
      allow read, write: if true;
    }

    // Ventas — público (el dashboard las gestiona sin Firebase Auth)
    match /ventas/{docId} {
      allow read, write: if true;
    }

    // Stock — público (el dashboard lo gestiona sin Firebase Auth)
    match /stock/{docId} {
      allow read, write: if true;
    }
  }
}
