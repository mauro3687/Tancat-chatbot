# ── WhatsApp Business API ──────────────────────────────────────
# Token de acceso permanente (Meta Developer Console)
WHATSAPP_TOKEN=EAAxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=1234567890

# Token de verificación del webhook (lo inventás vos, cualquier string)
WEBHOOK_VERIFY_TOKEN=tancat_webhook_2026

# ── Firebase Admin SDK ─────────────────────────────────────────
# Pegá el JSON completo de la service account de Firebase
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"tancat-system",...}

# ── Servidor ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
